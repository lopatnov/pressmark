{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "API: .NET (gRPC)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "api: build",
      "program": "${workspaceFolder}/src/Pressmark.Api/bin/Debug/net10.0/Pressmark.Api.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/Pressmark.Api",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5000",
        "ConnectionStrings__Default": "Server=localhost,1434;Database=pressmark;User Id=sa;Password=Dev_Password1!;TrustServerCertificate=True",
        "Jwt__Secret": "dev-secret-min-32-chars-do-not-use-in-prod!!",
        "Jwt__ExpiryMinutes": "15",
        "Jwt__RefreshExpiryDays": "7",
        "Jwt__RefreshCookieName": "refresh_token",
        "Cors__AllowedOrigins": "http://localhost:5173",
        "RssFetcher__IntervalMinutes": "15",
        "RssFetcher__MaxItemsPerFeed": "50"
      },
      "sourceFileMap": {
        "/Views": "${workspaceFolder}/Views"
      },
      "exceptionOptions": [
        {
          "path": [{ "names": ["Grpc.Core.RpcException"] }],
          "breakMode": "unhandled"
        }
      ]
    },
    {
      "name": "Web: Vite dev server",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/src/pressmark-web",
      "console": "integratedTerminal",
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "Local:.*http://localhost:([0-9]+)"
      }
    },
    {
      "name": "Browser: Chrome (localhost:5173)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/src/pressmark-web/src",
      "sourceMapPathOverrides": {
        "webpack:///src/*": "${webRoot}/*"
      }
    }
  ],
  "compounds": [
    {
      "name": "Full Stack (API + Vite)",
      "configurations": ["API: .NET (gRPC)", "Web: Vite dev server"],
      "stopAll": true
    }
  ]
}
