{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "api: build",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/src/Pressmark.Api/Pressmark.Api.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "problemMatcher": "$msCompile",
      "dependsOn": ["db: start"]
    },
    {
      "label": "api: watch",
      "command": "dotnet",
      "type": "process",
      "args": [
        "watch",
        "--project",
        "${workspaceFolder}/src/Pressmark.Api/Pressmark.Api.csproj"
      ],
      "problemMatcher": "$msCompile",
      "isBackground": true
    },
    {
      "label": "web: dev",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/src/pressmark-web"
      },
      "problemMatcher": [],
      "isBackground": true
    },
    {
      "label": "db: start",
      "type": "shell",
      "command": "docker compose up db -d",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
