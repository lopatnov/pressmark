# ─────────────────────────────────────────────────────────────────────────────
# Pressmark — environment variables
#
# Default values are intentionally weak and suitable for local use only.
# BEFORE DEPLOYING TO PRODUCTION change MSSQL_SA_PASSWORD, JWT_SECRET,
# and CORS_ALLOWED_ORIGINS to strong, unique values.
# ─────────────────────────────────────────────────────────────────────────────

# SQL Server SA password (must contain uppercase + lowercase + digit + symbol)
# Production: use a strong random password
MSSQL_SA_PASSWORD=Dev_Password1!

# JWT signing secret (min 32 chars)
# Production: openssl rand -base64 32
JWT_SECRET=dev-only-jwt-secret-change-before-production

# Allowed CORS origins, comma-separated, no trailing slash
# Production: set to your public domain, e.g. https://your-domain.com
CORS_ALLOWED_ORIGINS=http://localhost
